<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTFI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="LTFI.Views.PlaceholderView"
             x:DataType="vm:PlaceholderViewModel"
             mc:Ignorable="d">

    <StackPanel Margin="28" Spacing="14">
        <TextBlock Classes="page-title" Text="{Binding Title}"/>
        <Border Classes="card">
            <TextBlock Classes="muted" TextWrapping="Wrap" Text="{Binding Message}"/>
        </Border>
    </StackPanel>
</UserControl>
