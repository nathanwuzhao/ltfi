<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTFI.ViewModels"
             xmlns:domain="using:LTFI.Core.Domain"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="LTFI.Views.TodayView"
             x:DataType="vm:TodayViewModel"
             mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*" Margin="28">
        <TextBlock Classes="page-title" Text="{Binding Header}"/>
        <TextBlock Grid.Row="1" Classes="muted" Margin="0,6,0,18" Text="{Binding SummaryText}"/>

        <Border Grid.Row="2" Classes="card" Padding="8">
            <Panel>
                <TextBlock Classes="muted"
                           Margin="12"
                           VerticalAlignment="Top"
                           Text="Nothing due today. Plan work from the Tasks page."
                           IsVisible="{Binding !HasTasks}"/>

                <ListBox ItemsSource="{Binding TodayTasks}"
                         Background="Transparent"
                         IsVisible="{Binding HasTasks}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:TaskItem">
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Classes="muted" FontSize="12"
                                               Text="{Binding Description, FallbackValue=''}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="chip" Margin="8,0">
                                    <TextBlock Text="{Binding Priority}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Content="Complete"
                                        Command="{ReflectionBinding $parent[UserControl].DataContext.CompleteTaskCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </Border>
    </Grid>
</UserControl>
