<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTFI.ViewModels"
             xmlns:domain="using:LTFI.Core.Domain"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="LTFI.Views.TodayView"
             x:DataType="vm:TodayViewModel"
             mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="28">
        <TextBlock Classes="page-title" Text="{Binding Header}"/>
        <TextBlock Grid.Row="1" Classes="muted" Margin="0,6,0,14" Text="{Binding SummaryText}"/>

        <!-- Stat strip: quick-start + points + streak -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*" Margin="0,0,0,12">
            <Button Classes="primary" Content="Start focus"
                    Command="{Binding StartFocusCommand}"
                    ToolTip.Tip="Select a task below to start a focus session"/>
            <Border Grid.Column="1" Classes="chip" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Points today:"/>
                    <TextBlock Text="{Binding PointsToday}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="chip" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Focus streak:"/>
                    <TextBlock Text="{Binding FocusStreakDays}"/>
                    <TextBlock Text="d"/>
                </StackPanel>
            </Border>
            <TextBlock Grid.Column="3"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource WarningBrush}"
                       Text="{Binding FeedbackMessage}"/>
        </Grid>

        <!-- Active focus session banner -->
        <Border Grid.Row="3" Classes="card" Margin="0,0,0,12"
                Padding="14,10"
                IsVisible="{Binding HasActiveSession}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Classes="section-header" Text="IN FOCUS" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveSessionText}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Classes="card" Padding="8">
            <Panel>
                <TextBlock Classes="muted"
                           Margin="12"
                           VerticalAlignment="Top"
                           Text="Nothing due today. Plan work from the Tasks page."
                           IsVisible="{Binding !HasTasks}"/>

                <ListBox ItemsSource="{Binding TodayTasks}"
                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                         Background="Transparent"
                         IsVisible="{Binding HasTasks}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:TaskItem">
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="4">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Classes="muted" FontSize="12"
                                               Text="{Binding Description, FallbackValue=''}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="chip" Margin="8,0">
                                    <TextBlock Text="{Binding Priority}"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Content="Complete"
                                        Command="{ReflectionBinding $parent[UserControl].DataContext.CompleteTaskCommand}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>
        </Border>
    </Grid>
</UserControl>
