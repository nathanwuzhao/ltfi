<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTFI.ViewModels"
             xmlns:domain="using:LTFI.Core.Domain"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="LTFI.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel"
             mc:Ignorable="d">

    <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,*" Margin="28">
        <TextBlock Grid.ColumnSpan="2" Classes="page-title" Text="{Binding Header}"/>

        <!-- Project list -->
        <Border Grid.Row="1" Classes="card" Margin="0,18,12,0">
            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Content="New Project"
                            Classes="primary"
                            HorizontalAlignment="Left"
                            Command="{Binding NewProjectCommand}"/>
                    <CheckBox Grid.Column="2"
                              Content="Show archived"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowArchived, Mode=TwoWay}"/>
                </Grid>

                <ListBox Grid.Row="1"
                         Margin="0,14,0,0"
                         Background="Transparent"
                         ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="domain:Project">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="2">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Classes="muted" FontSize="12"
                                               Text="{Binding Description, FallbackValue=''}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Classes="chip">
                                    <TextBlock Text="{Binding Status}"/>
                                </Border>
                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2"
                                             Margin="0,8,0,0" Height="4" Maximum="100"
                                             Value="{Binding ProgressPercent, TargetNullValue=0}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Editor -->
        <Border Grid.Row="1" Grid.Column="1" Classes="card" Margin="0,18,0,0">
            <ScrollViewer>
                <StackPanel Spacing="14">
                    <TextBlock Classes="page-title" FontSize="20" Text="{Binding EditorTitle}"/>

                    <!-- Active-project-limit decision -->
                    <Border Classes="card"
                            BorderBrush="{DynamicResource WarningBrush}"
                            IsVisible="{Binding IsResolvingLimit}">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="section-header" Text="ACTIVE PROJECT LIMIT REACHED"/>
                            <TextBlock Classes="muted" TextWrapping="Wrap"
                                       Text="Pause or kill an active project to make room — or cancel."/>
                            <ItemsControl ItemsSource="{Binding ActiveProjectsToResolve}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="domain:Project">
                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,3">
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="Pause" Margin="0,0,8,0"
                                                    Command="{ReflectionBinding $parent[UserControl].DataContext.PauseToMakeRoomCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="2" Classes="danger" Content="Kill"
                                                    Command="{ReflectionBinding $parent[UserControl].DataContext.KillToMakeRoomCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Cancel activation" HorizontalAlignment="Left"
                                    Command="{Binding CancelActivationCommand}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="TITLE"/>
                        <TextBox Text="{Binding DraftTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="DESCRIPTION"/>
                        <TextBox Text="{Binding DraftDescription, Mode=TwoWay}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="STATUS"/>
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding SelectedStatus, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="DONE CONDITION"/>
                        <TextBox Text="{Binding DraftDoneCondition, Mode=TwoWay}"
                                 PlaceholderText="What does finishing this project look like?"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="TARGET DATE"/>
                        <TextBox Text="{Binding DraftTargetDateText, Mode=TwoWay}"
                                 PlaceholderText="YYYY-MM-DD"/>
                    </StackPanel>

                    <!-- Progress is derived from task/subtask completion, not entered. -->
                    <StackPanel Spacing="6" IsVisible="{Binding !IsCreatingNew}">
                        <TextBlock Classes="section-header" Text="PROGRESS (FROM TASKS)"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <ProgressBar Maximum="100"
                                         VerticalAlignment="Center"
                                         Value="{Binding SelectedProject.ProgressPercent, TargetNullValue=0}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Classes="muted" Text="{Binding SelectedProject.ProgressPercent, TargetNullValue=0}"/>
                                <TextBlock Classes="muted" Text="%"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <TextBlock Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding FeedbackMessage}"/>

                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Button Classes="primary"
                                Content="{Binding SaveButtonText}"
                                Command="{Binding SaveProjectCommand}"/>
                        <Button Grid.Column="1"
                                Classes="danger"
                                Content="Delete"
                                Command="{Binding DeleteProjectCommand}"/>
                    </Grid>

                    <!-- Milestones (available once the project is saved) -->
                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,14,0,0"
                            IsVisible="{Binding CanManageMilestones}">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="section-header" Text="MILESTONES"/>

                            <ItemsControl ItemsSource="{Binding Milestones}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="domain:Milestone">
                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,2">
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Classes="chip" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Status}"/>
                                            </Border>
                                            <Button Grid.Column="2" Content="Toggle done" Margin="0,0,6,0"
                                                    Command="{ReflectionBinding $parent[UserControl].DataContext.ToggleMilestoneCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Grid.Column="3" Classes="danger" Content="Remove"
                                                    Command="{ReflectionBinding $parent[UserControl].DataContext.DeleteMilestoneCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <TextBox Text="{Binding NewMilestoneTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="Add a milestone…"/>
                                <Button Grid.Column="1" Content="Add" Command="{Binding AddMilestoneCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
