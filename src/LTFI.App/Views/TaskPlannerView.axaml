<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LTFI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Class="LTFI.Views.TaskPlannerView"
             x:DataType="vm:TaskPlannerViewModel"
             mc:Ignorable="d">
    <Grid ColumnDefinitions="2*,3*" RowDefinitions="Auto,*" Margin="20">
        <TextBlock Grid.ColumnSpan="2"
                   Text="{Binding Header}"
                   FontSize="28"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Background="#151A22"
                CornerRadius="12"
                Padding="12"
                Margin="0,18,12,0">
            <Grid RowDefinitions="Auto,*">
                <Button Content="New Task"
                        Padding="14,10"
                        HorizontalAlignment="Left"
                        Command="{Binding NewTaskCommand}"/>

                <ListBox Grid.Row="1"
                         Margin="0,14,0,0"
                         ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskItemViewModel">
                            <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" Background="#222938">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StatusText}" Opacity="0.75"/>
                                    <TextBlock Text="{Binding DueDateText}" Opacity="0.65"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#0F141B"
                CornerRadius="12"
                Padding="18"
                Margin="0,18,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding EditorTitle}"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Title" Opacity="0.72"/>
                        <TextBox Text="{Binding DraftTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Description" Opacity="0.72"/>
                        <TextBox Text="{Binding DraftDescription, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="100"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Priority" Opacity="0.72"/>
                            <ComboBox ItemsSource="{Binding Priorities}"
                                      SelectedItem="{Binding SelectedPriority, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Due Date" Opacity="0.72"/>
                            <TextBox Text="{Binding DraftDueDateText, Mode=TwoWay}"
                                     PlaceholderText="YYYY-MM-DD"/>
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Required Work Minutes" Opacity="0.72"/>
                            <TextBox Text="{Binding RequiredWorkMinutesText, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Points" Opacity="0.72"/>
                            <TextBox Text="{Binding PointsValueText, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding FeedbackMessage}"
                               Foreground="#F2C46D"
                               TextWrapping="Wrap"/>

                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Button Content="{Binding SaveButtonText}"
                                Padding="16,10"
                                Command="{Binding SaveTaskCommand}"/>
                        <Button Grid.Column="1"
                                Content="Delete"
                                Padding="16,10"
                                Command="{Binding DeleteSelectedTaskCommand}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
